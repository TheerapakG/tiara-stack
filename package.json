{
  "name": "tiara-stack-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "vp run -r format",
    "lint": "vp run -r lint",
    "test": "vp run -r test",
    "checks": "pnpm format && pnpm lint && pnpm test",
    "format:apply": "vp run -r format:apply",
    "build": "vp run -r build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@rocicorp/zero-sqlite3",
      "better-sqlite3"
    ],
    "overrides": {
      "better-auth": "1.4.18"
    },
    "patchedDependencies": {
      "better-auth@1.4.18": "patches/better-auth@1.4.18.patch"
    }
  }
}
