# Example environment file for Docker Compose local development.
# Run `pnpm compose:generate-secrets` to create deploy/compose/.env.
# See deploy/compose/README.md for setup details.

# ===== MANUAL CONFIGURATION =====
# Optional for localhost; leave blank unless testing cookie scope.
COOKIE_DOMAIN=
# Required when testing Discord OAuth locally.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Required when running sheet-bot locally.
DISCORD_TOKEN=
# Optional; leave blank to use the local-otel-sink service.
OTEL_EXPORTER_OTLP_ENDPOINT=

# ===== AUTO-GENERATED BY pnpm compose:generate-secrets =====
POSTGRES_PASSWORD=change-me-generated
POSTGRES_PORT=5432
REDIS_PASSWORD=change-me-generated
# Optional local Zero admin password; generated .env files fill this value.
ZERO_ADMIN_PASSWORD=

# ===== PUBLIC URLS =====
SHEET_AUTH_PUBLIC_BASE_URL=http://localhost:3002
SHEET_INGRESS_PUBLIC_BASE_URL=http://localhost:3000
SHEET_WEB_PUBLIC_BASE_URL=http://localhost:3001
TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3002
