{
  "name": "dfx-discord-utils",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./discord": {
      "types": "./dist/discord/index.d.mts",
      "default": "./dist/discord/index.mjs"
    },
    "./discord/cache": {
      "types": "./dist/discord/cache.d.mts",
      "default": "./dist/discord/cache.mjs"
    },
    "./discord/schema": {
      "types": "./dist/discord/schema.d.mts",
      "default": "./dist/discord/schema.mjs"
    },
    "./discord/gateway": {
      "types": "./dist/discord/gateway.d.mts",
      "default": "./dist/discord/gateway.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "default": "./dist/utils/index.mjs"
    },
    "./*": {
      "types": "./dist/*/index.d.mts",
      "default": "./dist/*/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "build": "vp pack"
  },
  "dependencies": {
    "@discordjs/builders": "^1.13.1",
    "discord-api-types": "^0.38.38",
    "ts-mixer": "^6.0.4",
    "unstorage": "^1.17.4"
  },
  "devDependencies": {
    "@typescript/native-preview": "latest",
    "dfx": "^0.127.0",
    "glob": "^11.0.3",
    "pathe": "^2.0.3",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "dfx": "^0.127.0",
    "effect": "^3.19.8"
  }
}
